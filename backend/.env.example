# =============================================================
# LinkForge – Backend Environment Variables (example)
# Copy this to .env and fill in your values
# =============================================================

# --- PostgreSQL (Neon / Supabase) ---
DATABASE_URL=postgresql://user:password@host:5432/db

# --- MongoDB (Atlas) ---
MONGODB_URI=mongodb+srv://user:password@cluster.url/db
MONGODB_DB=linkforge_analytics

# --- Redis (Upstash) ---
REDIS_URL=rediss://default:password@host:6379

# --- Kafka (Aiven) ---
# From Aiven console > Overview > Connection information:
#   Host + Port  ->  KAFKA_BOOTSTRAP_SERVERS
#   Username     ->  KAFKA_SASL_USERNAME (default: avnadmin)
#   Password     ->  KAFKA_SASL_PASSWORD (set under Authentication > SASL > Enable)
#   CA Cert      ->  Download ca.pem and place it at KAFKA_SSL_CA_PATH
KAFKA_BOOTSTRAP_SERVERS=host.aivencloud.com:port
KAFKA_SASL_USERNAME=avnadmin
KAFKA_SASL_PASSWORD=your-password
KAFKA_SSL_CA_PATH=./ca.pem

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your.email@gmail.com
FROM_NAME=LinkForge
FRONTEND_URL=http://localhost:3000

# --- JWT ---
SECRET_KEY=run-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- OAuth ---
GOOGLE_OAUTH_CLIENT_ID=your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

GITHUB_OAUTH_CLIENT_ID=your-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-client-secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback
